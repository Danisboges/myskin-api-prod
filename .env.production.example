NODE_ENV=production
PORT=3000

# Required
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public
JWT_SECRET=replace-with-a-long-random-production-secret

# Required for frontend access
CORS_ORIGINS=https://your-frontend-domain.com
FRONTEND_URL=https://your-frontend-domain.com
BACKEND_URL=https://your-backend-domain.com
PUBLIC_API_ORIGIN=https://myskin-api-prod-production.up.railway.app

# Optional: Google OAuth
# If GOOGLE_CALLBACK_URL is empty, backend builds it from BACKEND_URL:
# https://your-backend-domain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Optional: AI melanoma model service
# AI_BASE_URL=https://your-ai-service.example.com
# AI_PREDICT_URL=https://your-ai-service.example.com/predict
# AI_GRADCAM_URL=https://your-ai-service.example.com/viz
# AI_ACCESS_TOKEN=

# Chatbot Gemma API
GEMMA_API_URL=https://Danisboges-my-medgemma-space.hf.space/api/generate
# GEMMA_API_TIMEOUT_MS=60000
AI_BOT_USER_ID=

# Optional: SMTP email
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="MySkin" <no-reply@your-domain.com>
