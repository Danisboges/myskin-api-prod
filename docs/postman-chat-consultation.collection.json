                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('lastMessageId', json.data.id);",
                  "}",
                  "pm.test('Message sent', function () {",
                  "  pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Dokter, apakah hasil scan ini perlu pemeriksaan lanjutan?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/patient/consultations/{{consultationId}}/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
