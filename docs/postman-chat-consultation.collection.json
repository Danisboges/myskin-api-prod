        {
          "name": "Mark Specific Messages as Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messageIds\": [\"{{lastMessageId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/patient/consultations/{{consultationId}}/read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "patient",
                "consultations",
                "{{consultationId}}",
                "read"
              ]
            },
            "description": "Mark message tertentu sebagai read. Saat ini schema belum punya field `isRead`, jadi endpoint mengembalikan compatibility success."
          },
          "response": []
        },
        {
          "name": "Mark All Messages as Read",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/patient/consultations/{{consultationId}}/read-all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "patient",
                "consultations",
                "{{consultationId}}",
                "read-all"
              ]
            },
            "description": "Mark semua messages sebagai read. Saat ini endpoint bersifat compatibility karena schema belum menyimpan read state."
          },
          "response": []
        }
      ]
