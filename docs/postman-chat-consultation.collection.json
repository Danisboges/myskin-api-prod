                  "if (json.id) {",
                  "  pm.collectionVariables.set('doctorUserId', json.id);",
                  "}",
                  "pm.test('Doctor login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.role).to.eql('doctor');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{doctorEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login sebagai doctor. Token otomatis disimpan ke collection variable `doctorToken`."
          },
          "response": []
        },
        {
          "name": "Forgot Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.resetToken) {",
                  "  pm.collectionVariables.set('resetToken', json.resetToken);",
                  "}",
                  "pm.test('Forgot password accepted', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/forgot-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "forgot-password"
              ]
            },
            "description": "Request token reset password. Di non-production response menyertakan `resetToken` dan `resetUrl` agar mudah dites di Postman. Di production response tetap generic dan token seharusnya dikirim via email."
          },
          "response": []
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{resetToken}}\",\n  \"password\": \"{{newPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/reset-password",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "reset-password"
              ]
            },
            "description": "Reset password memakai token dari request Forgot Password. Password minimal 6 karakter."
          },
          "response": []
        },
        {
          "name": "Get Doctor Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.doctorId) {",
                  "  pm.collectionVariables.set('doctorId', json.data.doctorId);",
                  "}",
                  "pm.test('Doctor profile loaded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{doctorToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/doctor/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "doctor",
                "profile"
              ]
            },
            "description": "Ambil profile doctor dan simpan `doctorId` otomatis untuk request initiate consultation."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Patient Consultation",
      "item": [
        {
          "name": "Initiate Consultation",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.id) {",
                  "  pm.collectionVariables.set('consultationId', json.data.id);",
                  "}",
                  "pm.test('Consultation initiated or duplicate handled', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": \"{{doctorId}}\",\n  \"scanId\": \"{{scanId}}\",\n  \"initialMessage\": \"Halo dokter, saya ingin konsultasi terkait hasil scan saya.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/patient/consultations/initiate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "patient",
                "consultations",
                "initiate"
              ]
            },
            "description": "Membuat konsultasi baru dari patient ke doctor.\n\nBody:\n- `doctorId`: ID DoctorProfile, bukan userId doctor.\n- `scanId`: scanId publik, contoh `SCAN-SEED-002`.\n- `initialMessage`: pesan awal patient.\n\nResponse 201 akan menyimpan `consultationId` otomatis."
          },
          "response": []
        },
        {
          "name": "Get Patient Consultation List",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/patient/consultations?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "patient",
                "consultations"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Mengambil daftar konsultasi milik patient yang sedang login."
          },
          "response": []
        },
