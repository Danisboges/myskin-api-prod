
{
  "info": {
    "name": "Melanoma API - Chat Consultation",
    "description": "Postman collection untuk endpoint chat konsultasi antara patient dan doctor.\n\nCara pakai:\n1. Import file ini ke Postman.\n2. Jalankan request \"Login Patient\" untuk menyimpan {{patientToken}}.\n3. Jalankan request \"Login Doctor\" untuk menyimpan {{doctorToken}}.\n4. Jika perlu, ubah {{doctorId}} dan {{scanId}} di bagian Variables.\n5. Jalankan \"Initiate Consultation\". Response akan otomatis menyimpan {{consultationId}}.\n6. Lanjutkan test send/get messages, mark read, dan close consultation.\n\nDefault baseUrl: http://localhost:3300",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('patientToken', json.token);",
                  "}",
                  "if (json.id) {",
                  "  pm.collectionVariables.set('patientUserId', json.id);",
                  "}",
                  "pm.test('Patient login success', function () {",
                  "  pm.response.to.have.status(200);",
                  "  pm.expect(json.role).to.eql('patient');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login sebagai patient. Token otomatis disimpan ke collection variable `patientToken`."
          },
          "response": []
        },
        {
          "name": "Login Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
