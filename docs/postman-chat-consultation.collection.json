              ]
            },
            "description": "Mengambil detail konsultasi, termasuk scan, messages, dan report jika konsultasi sudah ditutup."
          },
          "response": []
        },
        {
          "name": "Send Message as Patient",
          "event": [
            {
              "listen": "test",
              "script": {
