                "patient",
                "consultations",
                "{{consultationId}}",
                "messages"
              ]
            },
            "description": "Kirim pesan sebagai patient. `lastMessageId` akan disimpan otomatis."
          },
          "response": []
        },
        {
          "name": "Get Messages as Patient",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{patientToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/patient/consultations/{{consultationId}}/messages?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "patient",
                "consultations",
                "{{consultationId}}",
                "messages"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Mengambil chat messages dengan pagination. Response data dikembalikan ascending untuk display."
          },
          "response": []
