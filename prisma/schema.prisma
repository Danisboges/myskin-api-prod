  // Log Information
  title                   String
  description             String              @db.Text
  severity                LogSeverity
  category                LogCategory
  
  // Additional Data
  metadata                String?             @db.Text // JSON metadata
  
  createdAt               DateTime            @default(now())
  
  @@index([severity, createdAt])
  @@index([category, createdAt])
