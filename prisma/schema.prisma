generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Hapus url = env("DATABASE_URL") di sini
}

// ==================== ENUMS ====================
enum Role {
  admin
  doctor
  patient
}

enum Gender {
  male
  female
}

enum ConsultationStatus {
  OPEN
  CLOSED
}

enum CaseReviewStatus {
  pending_review
  approved
  rejected
  under_review
}

enum NotificationType {
  case_request
  scan_complete
  verification_alert
  system_message
}

enum DataVisibility {
  restricted_clinical_team_only
  restricted_self_only
  shared_with_clinic
}

enum UserStatus {
  active
  pending
  suspended
  inactive
}

enum AuditAction {
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  CHANGE_USER_ROLE
  CHANGE_USER_STATUS
  RESET_PASSWORD
  APPROVE_DOCTOR
  REJECT_DOCTOR
  CREATE_CLINIC
  UPDATE_CLINIC
  DELETE_CLINIC
  CREATE_CLINIC_REQUEST
  APPROVE_CLINIC_REQUEST
  REJECT_CLINIC_REQUEST
  UPDATE_SYSTEM_SETTINGS
  GENERATE_REPORT
}

enum LogSeverity {
  critical
  warning
  info
}

enum LogCategory {
  infrastructure
  ai_engine
  user_management
  security
  system
}
model User {
  id        String     @id @default(uuid())
  name      String
  email     String     @unique
  googleId  String?    @unique
  password  String
  phone     String?
  role      Role       @default(patient)
  gender    Gender?
  birthDate DateTime?
  status    UserStatus @default(active)
  avatarUrl String?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relasi Profil
  doctorProfile      DoctorProfile?
  patientProfile     PatientProfile?
  adminSettings      AdminSettings?
  
  // Relasi Logika
  patientConsultations Consultation[] @relation("PatientToConsultation")
  doctorConsultations  Consultation[] @relation("DoctorToConsultation")
  messages             ChatMessage[]
  adminNotifications   AdminNotification[]
  auditLogs            AuditLog[]
}

// ==================== DOCTOR DOMAIN ====================

model DoctorProfile {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  clinicId            String?
  clinic              Clinic?  @relation(fields: [clinicId], references: [clinicId], onDelete: SetNull)
  verificationStatus  String   @default("unverified") // unverified, pending, verified
  practitionerLicense String?  
  licenseFile         String?
  specialization      String   @default("Dermatology")
  
  joinedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Relasi
  caseReviews         CaseReview[]
  observations        DoctorObservation[]
  settings            DoctorSettings?
  notifications       Notification[]
  caseAssignments     CaseAssignment[]
}

model Clinic {
  id          String          @id @default(uuid())
  clinicId    String          @unique @default(uuid())
  name        String
  address     String?         @db.Text
  phone       String?
  email       String?
  isActive    Boolean         @default(true)
  doctors     DoctorProfile[]
  requests    ClinicRequest[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([name])
  @@index([isActive])
}

model ClinicRequest {
  id                  String   @id @default(uuid())
  requestId           String   @unique @default(uuid())
  clinicName          String
  address             String?  @db.Text
  phone               String?
  email               String?
  requesterName       String
  requesterEmail      String
  requesterPhone      String?
  message             String?  @db.Text
  status              String   @default("pending")
  reviewNote          String?  @db.Text
  reviewedByAdminId   String?
  reviewedByAdminName String?
  reviewedAt          DateTime?
  clinicId            String?
  clinic              Clinic?  @relation(fields: [clinicId], references: [clinicId], onDelete: SetNull)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status, createdAt])
  @@index([clinicName])
  @@index([requesterEmail])
}

model DoctorSettings {
  id                 String         @id @default(uuid())
  doctorId           String         @unique
  doctor             DoctorProfile  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  twoFactorEnabled   Boolean        @default(false)
  emailNotifications Boolean        @default(true)
  verificationAlerts Boolean        @default(true)
  dataVisibility     DataVisibility @default(restricted_clinical_team_only)
  language           String         @default("English (US)")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

// ==================== PATIENT DOMAIN ====================

model PatientProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  medicalHistory String?  @db.Text 
  allergies      String?  @db.Text 
  medications    String?  @db.Text 
  familyHistory  String?  @db.Text 
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relasi
  scans                Scan[]
  verificationRequests VerificationRequest[]
  settings             PatientSettings?
  notifications        PatientNotification[]
  reports              Report[]
}

model PatientSettings {
  id                  String         @id @default(uuid())
  patientId           String         @unique
  patient             PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  twoFactorEnabled    Boolean        @default(false)
  emailNotifications  Boolean        @default(true)
  scanNotifications   Boolean        @default(true)
  reportNotifications Boolean        @default(true)
  dataVisibility      DataVisibility @default(restricted_self_only)
  language            String         @default("English (US)")
  theme               String         @default("light")
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

// ==================== CORE BUSINESS LOGIC (SCAN & CONSULTATION) ====================

// Ini adalah gabungan dari fitur Detection lama dan Scan baru
model Scan {
  id                 String   @id @default(uuid())
  scanId             String   @unique @default(uuid()) // Identifier unik scan
  
  patientId          String
  patient            PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  imageUrl           String   // URL gambar dari Cloudinary/S3
  annotatedImageUrl  String?
  complaint          String?  @db.Text // Keluhan awal pasien
  bodySite           String?  
  notes              String?  @db.Text
  
  // Hasil AI Engine
  isAnalyzed         Boolean  @default(false)
  aiPrediction       String?  // Melanoma/Benign
  aiConfidence       Float?   // Skor akurasi AI (0-1 atau persentase)
  aiDetails          String?  @db.Text // Metadata AI tambahan
  analyzeCompletedAt DateTime?
  gradcamUrl         String?
  
  // Izin Sharing ke Dokter
  isSharedWithDoctor Boolean  @default(false)
  sharedWith         String?  @db.Text // JSON list dokter ID yang boleh akses
  
  uploadedAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Alur Lanjutan
  consultation       Consultation?
  caseReview         CaseReview?
  reports            Report[]
}

model Consultation {
  id          String             @id @default(uuid())
  status      ConsultationStatus @default(OPEN)
  
  // Terhubung ke Scan, bukan lagi Detection
  scanId      String             @unique
  scan        Scan               @relation(fields: [scanId], references: [id])
  
  patientId   String
  patient     User               @relation("PatientToConsultation", fields: [patientId], references: [id])
  doctorId    String
  doctor      User               @relation("DoctorToConsultation", fields: [doctorId], references: [id])
  
  messages      ChatMessage[]
  prescriptions Prescription[]
  
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
}

model ChatMessage {
  id             String       @id @default(uuid())
  message        String       @db.Text
  timestamp      DateTime     @default(now())
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  attachments    ChatMessageAttachment[]
  readReceipts   ChatMessageReadReceipt[]
}

model ChatMessageAttachment {
  id          String      @id @default(uuid())
  messageId   String
  message     ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url         String
  fileName    String
  mimeType    String
  size        Int
  createdAt   DateTime    @default(now())

  @@index([messageId])
}

model ChatMessageReadReceipt {
  id        String      @id @default(uuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  readAt    DateTime    @default(now())

  @@unique([messageId, userId])
  @@index([userId, readAt])
}

model Prescription {
  id              String       @id @default(uuid())
  consultationId  String
  consultation    Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  doctorId        String
  patientId       String
  medicationName  String
  dosage          String?
  frequency       String?
  duration        String?
  notes           String?      @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([consultationId, createdAt])
}

// ==================== DOCTOR REVIEW & REPORTS ====================

model CaseReview {
  id                   String           @id @default(uuid())
  caseId               String           @unique @default(uuid())
  
  scanId               String           @unique
  scan                 Scan             @relation(fields: [scanId], references: [id], onDelete: Cascade)
  
  // Data Clinical Tambahan Dokter
  zoom                 String?          @default("4.0x")
  light                String?          @default("Polarized")
  
  doctorId             String?
  doctor               DoctorProfile?   @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  
  physicianObservation String?          @db.Text
  finalDiagnosis       String?
  reviewStatus         CaseReviewStatus @default(pending_review)
  rejectionReason      String?          @db.Text
  
  receivedAt           DateTime         @default(now())
  reviewedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  
  observations         DoctorObservation[]
}

model DoctorObservation {
  id           String        @id @default(uuid())
  caseReviewId String
  caseReview   CaseReview    @relation(fields: [caseReviewId], references: [id], onDelete: Cascade)
  doctorId     String
  doctor       DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  observation  String        @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Report {
  id                 String   @id @default(uuid())
  reportId           String   @unique @default(uuid())
  
  scanId             String
  scan               Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  patientId          String
  patient            PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  title              String
  description        String?  @db.Text
  diagnosis          String   
  recommendation     String?  @db.Text 
  caseDisposition    String?
  finalClinicalNotes String?  @db.Text
  pdfUrl             String?  
  
  status             String   @default("draft") 
  approvedByDoctorId String?
  approvedAt         DateTime?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  
  @@index([patientId, createdAt])
}

// ==================== NOTIFICATIONS & ADMIN ====================

model Notification {
  id             String           @id @default(uuid())
  doctorId       String
  doctor         DoctorProfile    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  notificationId String           @unique @default(uuid())
  title          String
  message        String           @db.Text
  type           NotificationType @default(system_message)
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model PatientNotification {
  id             String         @id @default(uuid())
  patientId      String
  patient        PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  notificationId String         @unique @default(uuid())
  title          String
  message        String         @db.Text
  type           String         
  isRead         Boolean        @default(false)
  readAt         DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model VerificationRequest {
  id                 String         @id @default(uuid())
  requestId          String         @unique @default(uuid())
  patientId          String
  patient            PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  message            String?        @db.Text
  assignedDoctorId   String?
  assignedDoctorName String?
  status             String         @default("pending")
  submittedAt        DateTime       @default(now())
  completedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model AdminSettings {
  id                 String         @id @default(uuid())
  adminId            String         @unique
  admin              User           @relation(fields: [adminId], references: [id], onDelete: Cascade)
  twoFactorEnabled   Boolean        @default(false)
  emailNotifications Boolean        @default(true)
  verificationAlerts Boolean        @default(true)
  doctorApprovalAlerts Boolean      @default(true)
  clinicRequestAlerts Boolean       @default(true)
  systemAlerts       Boolean        @default(true)
  weeklyDigest       Boolean        @default(false)
  defaultPageSize    Int            @default(8)
  auditLogRetentionDays Int         @default(180)
  maintenanceMode    Boolean        @default(false)
  deleteConfirmationRequired Boolean @default(true)
  dataVisibility     DataVisibility @default(restricted_clinical_team_only)
  language           String         @default("English (US)")
  timezone           String         @default("Asia/Jakarta")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model AdminNotification {
  id             String   @id @default(uuid())
  adminId        String
  admin          User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  notificationId String   @unique @default(uuid())
  title          String
  message        String   @db.Text
  type           String   
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([adminId, isRead])
}

model AuditLog {
  id                 String      @id @default(uuid())
  auditId            String      @unique @default(uuid())
  adminId            String
  admin              User        @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminName          String
  action             AuditAction
  description        String      @db.Text
  targetUserId       String?
  targetResourceType String?
  targetResourceId   String?
  ipAddress          String?
  userAgent          String?
  status             String      @default("success")
  createdAt          DateTime    @default(now())
  @@index([adminId, createdAt])
}

model SystemLog {
  id          String      @id @default(uuid())
  logId       String      @unique @default(uuid())
  title       String
  description String      @db.Text
  severity    LogSeverity
  category    LogCategory
  metadata    String?     @db.Text
  createdAt   DateTime    @default(now())
  @@index([severity, createdAt])
}

model CaseAssignment {
  id         String        @id @default(uuid())
  doctorId   String
  doctor     DoctorProfile @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  caseId     String
  assignedAt DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  @@unique([doctorId, caseId])
}
