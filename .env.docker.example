NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://postgres:postgres@db:5432/melanoma?schema=public
JWT_SECRET=change-this-secret-before-production

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173

# Optional: AI melanoma model service
# AI_BASE_URL=https://your-ai-service.example.com
# AI_PREDICT_URL=https://your-ai-service.example.com/predict
# AI_GRADCAM_URL=https://your-ai-service.example.com/viz
# AI_ACCESS_TOKEN=

# Optional: Ollama chatbot
# If Ollama runs on Windows host, Docker Desktop usually can access it with this URL.
OLLAMA_HOST=http://host.docker.internal:11434
AI_BOT_USER_ID=

# Optional: SMTP email
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="MySkin" <no-reply@myskin.local>
